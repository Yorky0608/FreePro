{
  "name": "vite-project",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:vite": "vite --host --port 5173 --strictPort",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev:desktop": "concurrently -k --success first -n VITE,ELECTRON -c auto npm:dev:vite npm:dev:electron",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "vite": "^8.0.1",
    "concurrently": "^9.2.1",
    "electron": "^38.0.0",
    "wait-on": "^9.0.4"
  }
}
